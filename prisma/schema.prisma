generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LogTag {
  campus
  work
  reflection
}

model LogEntry {
  id        String   @id @default(cuid())
  body      String
  tag       LogTag
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
